import tkinter as tk
from tkinter import messagebox
import json
import os


FILE_NAME = "contacts.phonebook"
contacts = []

BG = "#121212"
FRAME_BG = "#1e1e1e"
ENTRY_BG = "#2a2a2a"
FG = "white"
ACCENT = "#3b82f6"

CATEGORIES = ["Friends", "Family", "Work"]


def load_contacts():
    global contacts

    if os.path.exists(FILE_NAME):
        with open(FILE_NAME, "r") as file:
            try:
                contacts = json.load(file)
            except:
                contacts = []

def save_contacts():
    with open(FILE_NAME, "w") as file:
        json.dump(contacts, file, indent=4)


def add_placeholder(entry, placeholder):
    entry.delete(0, tk.END)
    entry.insert(0, placeholder)
    entry.config(fg="gray")

    def on_focus_in(event):
        if entry.get() == placeholder:
            entry.delete(0, tk.END)
            entry.config(fg="white")

    def on_focus_out(event):
        if entry.get().strip() == "":
            entry.delete(0, tk.END)
            entry.insert(0, placeholder)
            entry.config(fg="gray")

    entry.bind("<FocusIn>", on_focus_in)
    entry.bind("<FocusOut>", on_focus_out)


def refresh_list(data=None):
    listbox.delete(0, tk.END)

    show_data = data if data is not None else contacts

    for c in show_data:
        listbox.insert(
            tk.END,
            f"{c['name']} | {c['phone']} | {c['email']} | {c.get('category', 'N/A')}"
        )

def get_index():
    try:
        return listbox.curselection()[0]
    except:
        return None

def clear_fields():
    add_placeholder(entry_name, "Name")
    add_placeholder(entry_phone, "Phone")
    add_placeholder(entry_email, "Email")
    category_var.set(CATEGORIES[0])


def search_contact():
    keyword = search_entry.get().lower()

    if keyword in ["", "search contact"]:
        refresh_list()
        return

    filtered = []

    for c in contacts:
        if (
            keyword in c["name"].lower()
            or keyword in c["phone"].lower()
            or keyword in c["email"].lower()
            or keyword in c.get("category", "").lower()
        ):
            filtered.append(c)

    refresh_list(filtered)


def back_to_contacts():
    add_placeholder(search_entry, "Search Contact")
    refresh_list()


def view_contact():
    i = get_index()

    if i is None:
        messagebox.showwarning(
            "Error",
            "Select a contact first!"
        )
        return

    c = contacts[i]

    view = tk.Toplevel(app)
