        font=("Arial", 11)
    ).pack(pady=5)


def add_contact():
    name = entry_name.get()
    phone = entry_phone.get()
    email = entry_email.get()
    category = category_var.get()

    if (
        name in ["", "Name"]
        or phone in ["", "Phone"]
        or email in ["", "Email"]
    ):
        messagebox.showwarning(
            "Error",
            "All fields are required!"
        )
        return

    
    if not phone.isdigit():
        messagebox.showwarning(
            "Error",
            "Phone number must contain only numbers!"
        )
        return

    contacts.append({
        "name": name,
        "phone": phone,
        "email": email,
        "category": category
    })

    save_contacts()
    refresh_list()
    clear_fields()


def delete_contact():
    i = get_index()

    if i is None:
        messagebox.showwarning(
            "Error",
            "Select a contact first!"
        )
        return

    confirm = messagebox.askyesno(
        "Confirm Delete",
        "Are you sure you want to delete this contact?"
    )

    if confirm:
        contacts.pop(i)

        save_contacts()
        refresh_list()
        clear_fields()


def update_contact():
    i = get_index()

    if i is None:
        messagebox.showwarning(
            "Error",
            "Select a contact first!"
        )
        return

    name = entry_name.get()
    phone = entry_phone.get()
    email = entry_email.get()
    category = category_var.get()

    if (
        name in ["", "Name"]
        or phone in ["", "Phone"]
        or email in ["", "Email"]
    ):
        messagebox.showwarning(
            "Error",
            "All fields are required!"
        )
        return

    
    if not phone.isdigit():
        messagebox.showwarning(
            "Error",
            "Phone number must contain only numbers!"
        )
        return

    contacts[i] = {
        "name": name,
        "phone": phone,
        "email": email,
        "category": category
    }

    save_contacts()
    refresh_list()
    clear_fields()


def select_contact(event):
    i = get_index()

    if i is None:
        return

    c = contacts[i]

    entry_name.delete(0, tk.END)
    entry_phone.delete(0, tk.END)
    entry_email.delete(0, tk.END)

    entry_name.insert(0, c["name"])
    entry_phone.insert(0, c["phone"])
    entry_email.insert(0, c["email"])

    entry_name.config(fg="white")
    entry_phone.config(fg="white")
    entry_email.config(fg="white")

    category_var.set(c.get("category", "Friends"))


