import tkinter as tk
from tkinter import messagebox


contacts = []


def add_contact():
    name = entry_name.get()
    phone = entry_phone.get()
    email = entry_email.get()

    if name == "" or phone == "" or email == "":
        messagebox.showwarning("Input Error", "All fields are required!")
        return

    contact = f"{name} | {phone} | {email}"
    contacts.append(contact)
    listbox.insert(tk.END, contact)

    clear_fields()


def clear_fields():
    entry_name.delete(0, tk.END)
    entry_phone.delete(0, tk.END)
    entry_email.delete(0, tk.END)


def delete_contact():
    try:
        selected_index = listbox.curselection()[0]
        listbox.delete(selected_index)
        contacts.pop(selected_index)
    except:
        messagebox.showwarning("Selection Error", "No contact selected!")


def select_contact(event):
    try:
        selected_index = listbox.curselection()[0]
        selected_contact = contacts[selected_index]
        name, phone, email = selected_contact.split(" | ")

        entry_name.delete(0, tk.END)
        entry_name.insert(tk.END, name)

        entry_phone.delete(0, tk.END)
        entry_phone.insert(tk.END, phone)

        entry_email.delete(0, tk.END)
        entry_email.insert(tk.END, email)
    except:
        pass


def update_contact():
    try:
        selected_index = listbox.curselection()[0]
        name = entry_name.get()
        phone = entry_phone.get()
        email = entry_email.get()

        if name == "" or phone == "" or email == "":
            messagebox.showwarning("Input Error", "All fields are required!")
            return

        updated_contact = f"{name} | {phone} | {email}"
        contacts[selected_index] = updated_contact
        listbox.delete(selected_index)
        listbox.insert(selected_index, updated_contact)

        clear_fields()
    except:
        messagebox.showwarning("Selection Error", "No contact selected!")


root = tk.Tk()
root.title("Contact Manager")
root.geometry("400x400")


tk.Label(root, text="Name").pack()
entry_name = tk.Entry(root)
entry_name.pack()

tk.Label(root, text="Phone").pack()
entry_phone = tk.Entry(root)
entry_phone.pack()

tk.Label(root, text="Email").pack()
entry_email = tk.Entry(root)
entry_email.pack()


tk.Button(root, text="Add Contact", command=add_contact).pack(pady=5)
tk.Button(root, text="Update Contact", command=update_contact).pack(pady=5)
tk.Button(root, text="Delete Contact", command=delete_contact).pack(pady=5)
tk.Button(root, text="Clear Fields", command=clear_fields).pack(pady=5)


listbox = tk.Listbox(root)
listbox.pack(fill=tk.BOTH, expand=True)
listbox.bind('<<ListboxSelect>>', select_contact)


root.mainloop()
